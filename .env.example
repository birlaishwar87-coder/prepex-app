# ============================================================
# Prepex — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local. Never paste real keys into chat.
# ============================================================

# --- Supabase ---
# Public — bundled into the browser. URL and anon key are safe to expose.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS — guard like a password.
# Used by scheduled jobs / webhooks. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI provider — Groq (default, free) ---
# Server-only. Used by plan generation + chat when ANTHROPIC_API_KEY is unset.
GROQ_API_KEY=

# --- AI provider — Anthropic Claude (optional, paid) ---
# Server-only. When set, the app switches plan-gen + chat to Claude
# automatically. Leave blank to stay on Groq.
# Pricing: claude-haiku-4-5 is the cheapest (~$1/M input tokens).
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Optional overrides — defaults to claude-haiku-4-5 for both.
ANTHROPIC_PLAN_MODEL=
ANTHROPIC_CHAT_MODEL=

# --- Mixpanel (browser analytics) ---
# Public token — bundled into the browser. Optional.
# If missing, analytics is a no-op; the app still works.
NEXT_PUBLIC_MIXPANEL_TOKEN=
