# ============================================================
# Prepex — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local. Never paste real keys into chat.
# ============================================================

# --- Supabase ---
# Public — bundled into the browser. URL and anon key are safe to expose.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS — guard like a password.
# Used by scheduled jobs / webhooks. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Groq (AI plan generation) ---
# Server-only. All Groq calls happen in API routes / server actions.
GROQ_API_KEY=

# --- Mixpanel (browser analytics) ---
# Public token — bundled into the browser. Optional.
# If missing, analytics is a no-op; the app still works.
NEXT_PUBLIC_MIXPANEL_TOKEN=
