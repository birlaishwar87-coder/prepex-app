# ============================================================
# Prepex — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local. Never paste real keys into chat.
# ============================================================

# --- Supabase ---
# Public — bundled into the browser. URL and anon key are safe to expose.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS — guard like a password.
# Used by scheduled jobs / webhooks. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI provider (priority: Gemini > Anthropic > Groq) ---
# Set ONE. App picks the first one available at runtime.

# Google Gemini (recommended — free tier on Gemini 2.5 Flash is generous):
#   https://aistudio.google.com → Get API key
GEMINI_API_KEY=
# Optional overrides — default is gemini-2.5-flash for both.
# GEMINI_PLAN_MODEL=gemini-2.5-flash
# GEMINI_CHAT_MODEL=gemini-2.5-flash

# Anthropic Claude (paid, $5 trial credit):
#   https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Optional overrides — default is claude-haiku-4-5 for both.
ANTHROPIC_PLAN_MODEL=
ANTHROPIC_CHAT_MODEL=

# Groq (free but capped at 100K tokens/day):
#   https://console.groq.com → API keys
GROQ_API_KEY=

# --- Mixpanel (browser analytics) ---
# Public token — bundled into the browser. Optional.
# If missing, analytics is a no-op; the app still works.
NEXT_PUBLIC_MIXPANEL_TOKEN=
